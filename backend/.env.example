# ─────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Lista separada por vírgula (sem espaços). Em prod, configure os domínios reais.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─────────────────────────────────────────────────────────
# Banco de dados (MySQL)
# ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=usuario_banco
DB_PASSWORD=troque_este_valor_pela_senha_do_seu_banco
DB_NAME=patinhas

# ─────────────────────────────────────────────────────────
# JWT / Auth
# ─────────────────────────────────────────────────────────
# Use 64+ caracteres aleatórios em produção (openssl rand -hex 48)
JWT_ACCESS_SECRET=troque-em-producao-com-segredo-forte-de-pelo-menos-32-bytes
JWT_REFRESH_SECRET=troque-em-producao-com-outro-segredo-forte-de-pelo-menos-32-bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DIAS=30

# Cookie do refresh token
COOKIE_NOME_REFRESH=patinhas_rt
# Em produção, o front estará em HTTPS e este valor deve ser "true"
COOKIE_SECURE=false
# "lax" para fluxo padrão; "none" exige Secure=true (cross-site)
COOKIE_SAMESITE=lax

# bcrypt cost (10 = dev, 12 = produção)
BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────────────────
# Uploads / Storage
# ─────────────────────────────────────────────────────────
# Driver de armazenamento. Hoje: 'local'. Futuro: 's3' | 'r2'.
UPLOADS_DRIVER=local
# Onde os arquivos vivem em disco (criado automaticamente se não existir).
UPLOADS_DIR=./uploads
# Prefixo de URL servido por express.static.
UPLOADS_PUBLIC_PATH=/uploads
# Quando vazio, URLs retornadas são relativas (ex: /uploads/.../foo.webp).
# Quando preenchido, viram absolutas (ex: https://cdn.exemplo.com/uploads/...).
UPLOADS_BASE_URL=
# Limite por arquivo, em bytes. 5 MiB = 5242880.
UPLOADS_MAX_BYTES=5242880
